# ── Admin Auth ───────────────────────────────────────────────────────────────
# Plain-text password set at first run; the app hashes it with bcrypt on startup.
# Change this before deploying.
ADMIN_PASSWORD=ztguard-admin-2026

# Random string used to sign session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace_with_random_64_char_hex

# ── Pangolin API ──────────────────────────────────────────────────────────────
PANGOLIN_API_URL=https://pangolin.test01.ztguard.net/v1
PANGOLIN_API_KEY=your_pangolin_api_key_here
PANGOLIN_ORG_ID=your_org_id_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3100
BASE_PATH=/ztguard

# ── Polling ───────────────────────────────────────────────────────────────────
# How often (seconds) to poll Pangolin for new log entries
POLL_INTERVAL_SECONDS=30
